# Copy to .env and adjust. Everything is optional: with no .env at all the
# stack runs fully offline on the deterministic fake provider (SPEC 9).

# --- LLM per-step models (SPEC 4.9), format: provider:model_name ---
# Recommended production tiering (requires ANTHROPIC_API_KEY):
#MODEL_ROUTER=anthropic:claude-haiku-4-5
#MODEL_EXTRACTOR=anthropic:claude-sonnet-5
#MODEL_VALIDATOR=anthropic:claude-sonnet-5
#MODEL_RISK=anthropic:claude-sonnet-5
#MODEL_FALLBACK=anthropic:claude-opus-4-8
#ANTHROPIC_API_KEY=sk-ant-...

# Any LangChain provider works, e.g.:
#MODEL_EXTRACTOR=openai:gpt-4o
#OPENAI_API_KEY=sk-...

# --- Persistence ---
#DATABASE_URL=postgresql://kyc:kyc@localhost:5432/kyc
#PERSISTENCE_BACKEND=postgres   # or: memory (no Postgres needed)

# --- Tracing (SPEC 4.8): LangGraph reports to LangSmith automatically ---
#LANGSMITH_TRACING=true
#LANGSMITH_API_KEY=lsv2_...
#LANGSMITH_PROJECT=nordvik-kyc

# --- Business thresholds (defaults per SPEC 7) ---
#CONFIDENCE_THRESHOLD=0.75
#HIGH_VOLUME_THRESHOLD_INDIVIDUAL_EUR=10000
#HIGH_VOLUME_THRESHOLD_BUSINESS_EUR=50000

# --- Bounded execution (SPEC 4.7) ---
#MAX_STEP_RETRIES=2
#GRAPH_RECURSION_LIMIT=25
